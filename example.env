APP_ENV=development
HOST=0.0.0.0
PORT=8001
DB_PATH=./data/software_factory.db
GITHUB_WEBHOOK_SECRET=
MAX_AUTOFIX_PER_PR=3
MAX_CONCURRENT_RUNS=3
PR_LOCK_TTL_SECONDS=900
MAX_RETRY_ATTEMPTS=3
RETRY_BACKOFF_BASE_SECONDS=30
RETRY_BACKOFF_MAX_SECONDS=1800
# Comma-separated list of error codes that should not be retried (e.g., unsupported_project_type,checks_failed,head_sha_mismatch,ai_not_configured)
NON_RETRYABLE_ERROR_CODES=unsupported_project_type,checks_failed,head_sha_mismatch,ai_not_configured,ai_invalid_response,patch_apply_failed
BOT_LOGINS=github-actions[bot],dependabot[bot]
NOISE_COMMENT_PATTERNS=^/retest\b,^/resolve\b
MANAGED_REPO_PREFIXES=
AUTOFIX_COMMENT_AUTHOR=software-factory[bot]
LOG_DIR=logs
LOG_ARCHIVE_SUBDIR=archive
LOG_RETENTION_DAYS=7
WORKER_ID=worker-default
AI_PROVIDER=anthropic
AI_TIMEOUT_SECONDS=120
AI_MAX_OUTPUT_TOKENS=6000
AI_TEMPERATURE=0
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-7-sonnet-latest
ANTHROPIC_BASE_URL=https://api.anthropic.com
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1
OPENAI_BASE_URL=https://api.openai.com/v1
ZHIPU_API_KEY=
AGENT_SDKS=openhands,claude_agent_sdk
OPENHANDS_COMMAND=openhands
OPENHANDS_COMMAND_TIMEOUT_SECONDS=600
OPENHANDS_WORKTREE_BASE_DIR=.software-factory-worktrees
CLAUDE_AGENT_SDK_COMMAND=claude
CLAUDE_AGENT_SDK_PROVIDER=zhipu
CLAUDE_AGENT_SDK_BASE_URL=https://open.bigmodel.cn/api/anthropic
CLAUDE_AGENT_SDK_MODEL=glm-5
CLAUDE_AGENT_SDK_COMMAND_TIMEOUT_SECONDS=600
CLAUDE_AGENT_SDK_WORKTREE_BASE_DIR=.software-factory-worktrees
