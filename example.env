APP_ENV=development
HOST=0.0.0.0
PORT=8000
DB_PATH=./data/software_factory.db
GITHUB_WEBHOOK_SECRET=
MAX_AUTOFIX_PER_PR=3
MAX_CONCURRENT_RUNS=3
PR_LOCK_TTL_SECONDS=900
MAX_RETRY_ATTEMPTS=3
RETRY_BACKOFF_BASE_SECONDS=30
RETRY_BACKOFF_MAX_SECONDS=1800
# Comma-separated list of error codes that should not be retried (e.g., unsupported_project_type,checks_failed,head_sha_mismatch)
NON_RETRYABLE_ERROR_CODES=unsupported_project_type,checks_failed,head_sha_mismatch
BOT_LOGINS=github-actions[bot],dependabot[bot]
NOISE_COMMENT_PATTERNS=^/retest\b,^/resolve\b
MANAGED_REPO_PREFIXES=
AUTOFIX_COMMENT_AUTHOR=software-factory[bot]
LOG_DIR=logs
LOG_ARCHIVE_SUBDIR=archive
LOG_RETENTION_DAYS=7
WORKER_ID=worker-default
